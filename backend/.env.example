# Veritabanı
DB_URL=jdbc:postgresql://localhost:5432/nybutik
DB_USER=nybutik
DB_PASSWORD=nybutik

# JWT — minimum 32 karakter, güçlü rastgele string
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-32-chars

# Frontend
FRONTEND_URL=http://localhost:5173

# Depolama (local = MinIO, prod = Cloudflare R2)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_BUCKET=ny-butik-images
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_URL=http://localhost:9000/ny-butik-images

# E-posta (local test için Mailpit veya dev SMTP)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
EMAIL_FROM=noreply@nybutik.com
EMAIL_FROM_NAME=NY Butik

# Ödeme/Kargo sağlayıcı (local = mock)
PAYMENT_PROVIDER=mock
SHIPMENT_PROVIDER=mock

# Kargo
SHIPPING_BASE_FEE=49.90
FREE_SHIPPING_THRESHOLD=500.00
